<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

	<display-name>InterWeave Transformation Server</display-name>

	<!-- ===== Transaction Logging Filter (monitoring) ===== -->
	<filter>
		<filter-name>TransactionLoggingFilter</filter-name>
		<filter-class>com.interweave.monitoring.TransactionLoggingFilter</filter-class>
		<init-param>
			<param-name>enabled</param-name>
			<param-value>true</param-value>
		</init-param>
	</filter>
	<filter-mapping>
		<filter-name>TransactionLoggingFilter</filter-name>
		<url-pattern>/transform</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>TransactionLoggingFilter</filter-name>
		<url-pattern>/scheduledtransform</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>TransactionLoggingFilter</filter-name>
		<url-pattern>/iwxml</url-pattern>
	</filter-mapping>

	<!-- ===== Servlets ===== -->
	<servlet>
		<servlet-name>DefaultGateway</servlet-name>
		<display-name>DefaultGateway</display-name>
		<description>DefaultGateway</description>
		<servlet-class>org.openamf.DefaultGateway</servlet-class>
		<init-param>
			<param-name>OPENAMF_CONFIG</param-name>
			<param-value>/WEB-INF/openamf-config.xml</param-value>
			<description>Location of the OpenAMF config file.</description>
		</init-param>
		<load-on-startup>1</load-on-startup>
	</servlet>
	<servlet>
		<servlet-name>iwtransformationserver</servlet-name>
		<display-name>iwtransformationserver</display-name>
		<description>InterWeave ACS Daemon Application</description>
		<servlet-class>com.interweave.servlets.IWIndex</servlet-class>
		<init-param>
			<param-name>application</param-name>
			<param-value>iwtransformationserver</param-value>
			<description>InterWeave Application Name.</description>
		</init-param>
		<load-on-startup>1</load-on-startup>
	</servlet>
	<servlet>
		<servlet-name>logging</servlet-name>
		<display-name>logging</display-name>
		<description>InterWeave ACS Daemon Applications</description>
		<servlet-class>com.interweave.servlets.IWLogging</servlet-class>
		<load-on-startup>1</load-on-startup>
	</servlet>
	<servlet>
		<servlet-name>iwxml</servlet-name>
		<display-name>iwxml</display-name>
		<description>InterWeave ACS Daemon Application</description>
		<servlet-class>com.interweave.servlets.IWXmlRequest</servlet-class>
		<load-on-startup>1</load-on-startup>
	</servlet>
	<servlet>
		<servlet-name>transform</servlet-name>
		<display-name>transform</display-name>
		<description>InterWeave ACS Daemon Application</description>
		<servlet-class>com.interweave.servlets.IWTransform</servlet-class>
		<load-on-startup>1</load-on-startup>
	</servlet>
	<servlet>
		<servlet-name>IWScheduledTransform</servlet-name>
		<display-name>IWScheduledTransform</display-name>
		<description>InterWeave ACS Daemon Application</description>
		<servlet-class>com.interweave.servlets.IWScheduledTransform</servlet-class>
	</servlet>

	<!-- ===== Servlet Mappings ===== -->
	<servlet-mapping>
		<servlet-name>DefaultGateway</servlet-name>
		<url-pattern>/gateway</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>iwtransformationserver</servlet-name>
		<url-pattern>/index</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>iwxml</servlet-name>
		<url-pattern>/iwxml</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>transform</servlet-name>
		<url-pattern>/transform</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>logging</servlet-name>
		<url-pattern>/logging</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>IWScheduledTransform</servlet-name>
		<url-pattern>/scheduledtransform</url-pattern>
	</servlet-mapping>

	<session-config>
		<session-timeout>30</session-timeout>
	</session-config>
</web-app>
