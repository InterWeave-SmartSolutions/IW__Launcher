	<!-- Monitoring Context Listener - starts/stops metrics aggregation scheduler -->
	<listener>
		<listener-class>com.interweave.monitoring.service.MonitoringContextListener</listener-class>
		<description>
		Initializes monitoring services on application startup and gracefully shuts them down
		on application shutdown. Manages the MetricsAggregator scheduler lifecycle.
		</description>
	</listener>

	<!-- Security Headers Filter - adds X-Frame-Options, X-Content-Type-Options, etc. -->
	<filter>
		<filter-name>SecurityHeadersFilter</filter-name>
		<filter-class>com.interweave.web.SecurityHeadersFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>SecurityHeadersFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

	<!-- Error Handling Filter - catches uncaught exceptions -->
	<filter>
		<filter-name>ErrorHandlingFilter</filter-name>
		<filter-class>com.interweave.web.ErrorHandlingFilter</filter-class>
		<description>
		Global error handling filter that catches uncaught exceptions and
		transforms them into structured error responses with proper logging
		</description>
	</filter>
	<filter-mapping>
		<filter-name>ErrorHandlingFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

	<!-- CSRF Filter - protects JSP form submissions (excludes /api/* which uses Bearer tokens) -->
	<filter>
		<filter-name>CsrfFilter</filter-name>
		<filter-class>com.interweave.web.CsrfFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>CsrfFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

	<!-- Rate Limit Filter - prevents API abuse (100 requests per minute per IP) -->
	<filter>
		<filter-name>RateLimitFilter</filter-name>
		<filter-class>com.interweave.web.RateLimitFilter</filter-class>
		<init-param>
			<param-name>maxRequests</param-name>
			<param-value>100</param-value>
		</init-param>
		<init-param>
			<param-name>windowMs</param-name>
			<param-value>60000</param-value>
		</init-param>
	</filter>
	<filter-mapping>
		<filter-name>RateLimitFilter</filter-name>
		<url-pattern>/api/*</url-pattern>
	</filter-mapping>

	<!-- Token Auth Filter - bridges Bearer tokens to Tomcat sessions for proxy deployments -->
	<filter>
		<filter-name>ApiTokenAuthFilter</filter-name>
		<filter-class>com.interweave.businessDaemon.api.ApiTokenAuthFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>ApiTokenAuthFilter</filter-name>
		<url-pattern>/api/*</url-pattern>
	</filter-mapping>

