        	<servlet-class>com.interweave.businessDaemon.api.ApiAuditLogServlet</servlet-class>
        </servlet>
        <servlet-mapping>
        	<servlet-name>ApiAuditLogServlet</servlet-name>
        	<url-pattern>/api/admin/audit/*</url-pattern>
        </servlet-mapping>

        <!-- Engine Status API -->
        <servlet>
        	<servlet-name>ApiEngineStatusServlet</servlet-name>
        	<servlet-class>com.interweave.businessDaemon.api.ApiEngineStatusServlet</servlet-class>
        </servlet>
        <servlet-mapping>
        	<servlet-name>ApiEngineStatusServlet</servlet-name>
        	<url-pattern>/api/engine/*</url-pattern>
        </servlet-mapping>

        <!-- Webhook Receiver API -->
        <servlet>
        	<servlet-name>ApiWebhookReceiverServlet</servlet-name>
        	<servlet-class>com.interweave.businessDaemon.api.ApiWebhookReceiverServlet</servlet-class>
        </servlet>
        <servlet-mapping>
        	<servlet-name>ApiWebhookReceiverServlet</servlet-name>
        	<url-pattern>/api/webhooks/receive</url-pattern>
        </servlet-mapping>

        <!-- Workspace Sync API (IDE ↔ Portal) -->
        <servlet>
        	<servlet-name>ApiWorkspaceSyncServlet</servlet-name>
        	<servlet-class>com.interweave.businessDaemon.api.ApiWorkspaceSyncServlet</servlet-class>
        </servlet>
        <servlet-mapping>
        	<servlet-name>ApiWorkspaceSyncServlet</servlet-name>
        	<url-pattern>/api/sync/*</url-pattern>
        </servlet-mapping>

        <!-- Associate Portal API -->
        <servlet>
        	<servlet-name>ApiAssociateServlet</servlet-name>
        	<servlet-class>com.interweave.businessDaemon.api.ApiAssociateServlet</servlet-class>
        </servlet>
        <servlet-mapping>
        	<servlet-name>ApiAssociateServlet</servlet-name>
        	<url-pattern>/api/associate/*</url-pattern>
        </servlet-mapping>

        <!-- Master Console API -->
        <servlet>
        	<servlet-name>ApiMasterServlet</servlet-name>
        	<servlet-class>com.interweave.businessDaemon.api.ApiMasterServlet</servlet-class>
        </servlet>
        <servlet-mapping>
        	<servlet-name>ApiMasterServlet</servlet-name>
        	<url-pattern>/api/master/*</url-pattern>
        </servlet-mapping>

	<session-config>
		<session-timeout>30</session-timeout>
		<cookie-config>
			<http-only>true</http-only>
			<!-- NOTE: Do NOT set <secure>true</secure> until TLS is enabled.
			     Setting Secure on cookies over plain HTTP would prevent login entirely. -->
		</cookie-config>
	</session-config>

	<!-- Custom error pages to prevent information leakage via stack traces -->
	<error-page>
		<error-code>400</error-code>
		<location>/error.html</location>
	</error-page>
	<error-page>
		<error-code>403</error-code>
		<location>/error.html</location>
	</error-page>
	<error-page>
		<error-code>404</error-code>
		<location>/error.html</location>
	</error-page>
	<error-page>
		<error-code>500</error-code>
		<location>/error.html</location>
	</error-page>
	<error-page>
		<exception-type>java.lang.Throwable</exception-type>
		<location>/error.html</location>
	</error-page>

</web-app>
