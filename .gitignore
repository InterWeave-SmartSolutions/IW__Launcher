# IW_IDE Git Ignore File

# ===== Local Configuration =====
config.local.ini
*.local.ini
*.local

# ===== Database Files =====
# Keep schema, ignore actual database
database/*.db
database/*.db-journal
database/*.db-wal
database/*.db-shm

# ===== Data Directories =====
# Keep directory structure, ignore user data
data/pages/*
data/forms/*
data/projects/*
data/exports/*
!data/pages/.gitkeep
!data/forms/.gitkeep
!data/projects/.gitkeep
!data/exports/.gitkeep

# ===== Eclipse Runtime State =====
# Generated on each IDE launch — machine-specific, not portable
configuration/org.eclipse.core.runtime/
configuration/org.eclipse.osgi/

# ===== Workspace =====
# User-specific workspace data
workspace/.metadata/
workspace/*/.settings/
workspace/*/bin/
workspace/*/target/
workspace/*/.project
workspace/*/.classpath

# ===== IDE Generated =====
configuration/.log
configuration/org.eclipse.core.runtime/.manager/
configuration/org.eclipse.osgi/.manager/
configuration/org.eclipse.osgi/bundles/
configuration/org.eclipse.update/
admstore.ast

# ===== JRE Temporary Files =====
jre.partial.*
tatus

# ===== Java/Eclipse =====
*.class
*.jar
!startup.jar
!plugins/**/*.jar
*.war
*.ear
.project
.classpath
.settings/
bin/
!plugins/iw_workspace_init_1.0.0/bin/
!plugins/iw_workspace_init_1.0.0/bin/**
target/
out/

# ===== Deployed Application (MUST be tracked for fresh clones) =====
# Override *.class and *.jar ignores for the actual deployed webapp
!web_portal/tomcat/webapps/iw-business-daemon/WEB-INF/classes/**
!web_portal/tomcat/webapps/iw-business-daemon/WEB-INF/lib/**
!web_portal/tomcat/lib/mysql-connector-java-*.jar
# Transformation server vendor JARs (copied from RDP server - required for /transform to function)
# Without these, iwtransformationserver returns 404 on all requests
!web_portal/tomcat/webapps/iwtransformationserver/WEB-INF/lib/**
# JAXB 1.0-ea trimmed JAR (endorsed override - fixes InstantiationError on Tomcat startup)
!jre/lib/endorsed/**
# Tomcat endorsed JARs (trimmed JAXB + XJC - replaces full jaxb-rt to avoid DOM Level 1 conflict)
!web_portal/tomcat/endorsed/**
# Override *.class and bin/ ignores for the iw_sdk Eclipse plugin (required for IDE to launch)
!plugins/iw_sdk_1.0.0/bin/
!plugins/iw_sdk_1.0.0/bin/**

# ===== Logs =====
*.log
logs/
log/

# ===== OS Generated =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ===== IDE Files =====
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo
*~

# ===== Backup Files =====
*.bak
*.backup
*.orig
*.tmp
*.temp
*.save

# ===== Test/Debug Artifacts =====
scripts/test_db.ps1
scripts/extract_strings.ps1
web_portal/tomcat/webapps/iw-business-daemon/db_test.jsp

# ===== Archives (don't commit large archives) =====
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# ===== Sensitive Data =====
**/credentials*
**/secrets*
**/*password*
**/*token*
.env
.env.local
.env.production
.env.*.local

# Override *password* ignore for ChangePassword feature files (these are CODE, not secrets)
!**/LocalChangePasswordServlet.*
!**/ChangePasswordPage.*
!**/ForgotPasswordPage.*
!**/ApiPasswordResetServlet.*
!**/ApiChangePasswordServlet.*
!**/mfa_password_reset_schema_postgres.sql
!**/LocalChangeCompanyPasswordServlet.*
!**/ChangePassword.jsp
!**/ChangeCompanyPassword.jsp
!**/PasswordHasher.*

# ===== Database Connection (configured per-machine) =====
web_portal/tomcat/conf/context.xml
web_portal/tomcat/webapps/iw-business-daemon/WEB-INF/config.xml

# ===== Tomcat Work Directory (compiled JSPs - regenerated at runtime) =====
web_portal/tomcat/work/

# ===== Node Modules & Lock Files =====
node_modules/
package-lock.json

# ===== Downloaded Dependencies =====
# PostgreSQL driver MUST be tracked - required for Supabase connectivity
!web_portal/tomcat/lib/postgresql-*.jar


# ===== AI Tool Config (user-specific) =====
.claude_settings.json
.auto-claude-status
.claude/
.playwright-mcp/
firebase-debug.log

# ===== Media (large files) =====
# Tutorial/training videos should not be committed.
docs/tutorials/*.mp4
docs/tutorials/*.m4v

# Audio
*.mp3

# ===== Monitoring Config (contains SMTP credentials) =====
web_portal/tomcat/webapps/iw-business-daemon/WEB-INF/monitoring.properties
!web_portal/tomcat/webapps/iw-business-daemon/WEB-INF/monitoring.properties.template

# ===== IW Portal (React app) =====
frontends/iw-portal/node_modules/
frontends/iw-portal/dist/
# iw-portal build output IS tracked so fresh clones get a working React portal
# (re-commit after each production build: git add web_portal/tomcat/webapps/iw-portal/)
!web_portal/tomcat/webapps/iw-portal/**

.vercel

# ===== Production Reference (large files + secrets) =====
# IDE distribution ZIP too large for GitHub (307MB)
docs/production-reference/iw-ide/IW_IDE.zip
# Client-specific engine logs contain Salesforce access tokens (also >100MB)
docs/production-reference/engine-logs/client-specific/
# IWCustomerPortal sites contain Salesforce OAuth consumer key/secret in config.json
docs/production-reference/sites/IWCustomerPortal/
docs/production-reference/sites/IWCustomerPortal-Win3/
# IDE data files contain live Salesforce session IDs, Stripe API keys, and credentials
docs/production-reference/iw-ide/Charge03.xml
docs/production-reference/iw-ide/Data/
docs/production-reference/iw-ide/transactions_old.xml
# .iwxt transaction exports and templates may contain embedded credentials
docs/production-reference/**/*.iwxt
# Extracted workspace projects contain plaintext credentials in config.xml (DB passwords, SMTP creds, API keys)
docs/production-reference/workspace-projects/all_projects_1/
docs/production-reference/workspace-projects/all_projects_2/
docs/production-reference/workspace-projects/NexternalHostedIan/
docs/production-reference/workspace-projects/NexternalQueryTest/
docs/production-reference/workspace-projects/NexternalQueryTestD/
docs/production-reference/workspace-projects/NexternalQueryTestIan/
docs/production-reference/workspace-projects/QB_sample/
docs/production-reference/workspace-projects/SN2QBSP/
docs/production-reference/workspace-projects/SN_Test/
docs/production-reference/workspace-projects/SN_Test_New/
docs/production-reference/workspace-projects/SPworkspace/
docs/production-reference/workspace-projects/SSProject/
docs/production-reference/workspace-projects/SalesProdigy1/
docs/production-reference/workspace-projects/IWHostedSolutions/IWHostedSolutions/
docs/production-reference/workspace-projects/IWHostedSolutions/test111/
docs/production-reference/workspace-projects/sample_projects/
docs/production-reference/workspace-projects/iw_ide/
docs/production-reference/workspace-projects/sdk_templates/
