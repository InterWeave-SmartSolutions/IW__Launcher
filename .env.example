# =============================================================================
# IW_IDE Environment Configuration
# =============================================================================
# This file is copied to .env on first run.
# The default is shared Supabase mode for team use.
# Replace the Supabase password placeholder before first successful startup.
# Switch to local or InterWeave hosted DB mode later if needed.
#
# DB_MODE options:  supabase | interweave | local
# =============================================================================

# =============================================================================
# DATABASE MODE - Default to Supabase for shared team startup
# =============================================================================
DB_MODE=supabase

# =============================================================================
# TRANSFORMATION / LOG ENDPOINT MODE
# =============================================================================
# Controls where flow queries and log links point.
# Keep this separate from DB_MODE:
# - DB_MODE chooses where profile/auth data is stored
# - TS_MODE chooses where runtime flow/log requests are sent
#
# TS_MODE options: local | legacy
# local  = use this repo's bundled Tomcat at localhost:9090 (default)
# legacy = point runtime flow/log URLs at the historical InterWeave host

TS_MODE=local
TS_BASE_LOCAL=http://localhost:9090/iwtransformationserver
TS_BASE_LEGACY=http://iw0.interweave.biz:9090/iwtransformationserver
TS_FAILOVER_LOCAL=
TS_FAILOVER_LEGACY=http://iw0.interweave.biz:8080/iw-business-daemon/failover

# =============================================================================
# SUPABASE POSTGRES (Shared Cloud Database - Optional)
# =============================================================================
# Team database hosted on Supabase.  SSL is enforced automatically.
# Get credentials from: Supabase Dashboard -> Settings -> Database
# Direct connection (port 5432) — preferred but may be blocked on some networks.
# Pooler connection (port 6543) — fallback. START.bat auto-detects which to use.
# Replace the password placeholder below with the shared team password.

SUPABASE_DB_HOST=db.hpodmkchdzwjtlnxjohf.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=YOUR_SUPABASE_PASSWORD_HERE

# Pooler fallback (used automatically if direct host is unreachable)
# Get values from Supabase Dashboard -> Settings -> Database -> Connection string (Pooler)
SUPABASE_POOLER_HOST=aws-0-us-west-2.pooler.supabase.com
SUPABASE_POOLER_PORT=6543
SUPABASE_POOLER_USER=postgres.hpodmkchdzwjtlnxjohf

# =============================================================================
# INTERWEAVE SERVER (Alternative - May Not Work Externally)
# =============================================================================
# Only use if you have InterWeave credentials and whitelisted IP.
# Change DB_MODE to 'interweave' to use these.

IW_DB_HOST=***********
IW_DB_PORT=3306
IW_DB_NAME=hostedprofiles
IW_DB_USER=
IW_DB_PASSWORD=

# =============================================================================
# DO NOT EDIT BELOW THIS LINE
# =============================================================================
