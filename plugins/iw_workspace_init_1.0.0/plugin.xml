<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.0"?>
<plugin
   id="iw_workspace_init"
   name="IW Workspace Auto-Import"
   version="1.0.0"
   provider-name="InterWeave">

   <requires>
      <import plugin="org.eclipse.core.resources"/>
      <import plugin="org.eclipse.core.runtime"/>
      <import plugin="org.eclipse.ui"/>
   </requires>

   <extension point="org.eclipse.ui.startup">
      <startup class="com.interweave.workspace.AutoImportStartup"/>
   </extension>

</plugin>
