# =============================================================================
# Line ending normalization
# =============================================================================
# Default: auto-detect text files, normalize to LF in repo
* text=auto eol=lf

# Windows batch scripts MUST have CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts MUST have LF
*.sh text eol=lf

# Explicit text files
*.md text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.java text eol=lf
*.jsp text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf

# Explicit binary files (never normalize)
*.exe binary
*.jar binary
*.war binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary

# =============================================================================
# Git LFS
# =============================================================================
docs/tutorials/*.mp4 filter=lfs diff=lfs merge=lfs -text
